{
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/.well-known/:path*",
        "destination": "/.well-known/:path*"
      },
      {
        "source": "/",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/.well-known/(.*)",
        "headers": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
        ]
      }
    ]
  }